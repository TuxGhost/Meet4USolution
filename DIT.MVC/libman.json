{
  "version": "1.0",
  "defaultProvider": "cdnjs",
  "libraries": [
    {
      "library": "datatables@1.10.21",
      "destination": "wwwroot/lib/datatables/"
    },

    {
      "library": "jquery@3.5.1",
      "destination": "wwwroot/lib/jquery/dist/",
      "files": [
        "jquery.min.js"
      ]
    },
    {
      "provider": "cdnjs",
      "library": "jquery-validate@1.17.0",
      "destination": "wwwroot/jquery-validation/dist",
      "files": [
        "jquery.validate.min.js"
      ]
    },
    {
      "provider": "cdnjs",
      "library": "jquery-validation-unobtrusive@3.2.11",
      "destination": "wwwroot/jquery-validation-unobtrusive/",
      "files": [
        "jquery.validate.unobtrusive.min.js"
      ]
    },
    {
      "provider": "cdnjs",
      "library": "bootstrap@5.1.0",
      "destination": "wwwroot/lib/bootstrap/dist",
      "files": [
        "css/bootstrap.css",
        "css/bootstrap-grid.css",
        "css/bootstrap-reboot.css",
        "css/bootstrap-utilities.css",
        "js/bootstrap.min.js",
        "css/bootstrap.min.css",
        "css/bootstrap.rtl.css",
        "css/bootstrap-grid.min.css",
        "css/bootstrap-grid.rtl.css",
        "css/bootstrap-reboot.css",
        "css/bootstrap-reboot.css.map",
        "css/bootstrap-reboot.min.css",
        "css/bootstrap-reboot.rtl.css",
        "css/bootstrap-utilities.css.map",
        "css/bootstrap-utilities.css",
        "css/bootstrap-utilities.rtl.css",
        "js/bootstrap.min.js",
        "js/bootstrap.bundle.js",
        "js/bootstrap.esm.js",
        "js/bootstrap.js.map"
      ]
    },
    {
      "library": "jquery@3.5.1",
      "destination": "wwwroot/lib/jquery/dist/",
      "files": [
        "jquery.min.js"
      ]
    },
    {
      "provider": "cdnjs",
      "library": "jquery-validate@1.17.0",
      "destination": "wwwroot/jquery-validation/dist",
      "files": [
        "jquery.validate.min.js"
      ]
    },
    {
      "provider": "cdnjs",
      "library": "jquery-validation-unobtrusive@3.2.11",
      "destination": "wwwroot/jquery-validation-unobtrusive/",
      "files": [
        "jquery.validate.unobtrusive.min.js"
      ]
    },
    {
      "provider": "cdnjs",
      "library": "datatables@1.10.21",
      "destination": "wwwroot/lib/datatables/"
    },
    {
      "provider": "cdnjs",
      "library": "datatables.net-select@1.3.1",
      "destination": "wwwroot/lib/datatables/js/"
    }

  ]
}